---
import cliPackage from "../../../../packages/cli/package.json";
import TinyloopMark from "./TinyloopMark.astro";

const { version } = cliPackage;
---

<header class="site-header" data-floating="false">
  <a class="brand-mark" href="/" aria-label="tinyloop home">
    <TinyloopMark />
    <span class="brand-name">tinyloop</span>
    <span class="brand-version">v{version}</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href="/architecture/">Architecture</a>
    <a href="/principles/">Principles</a>
    <div class="site-nav-group">
      <a class="site-nav-parent" href="/walkthroughs/">Walkthroughs</a>
      <div class="site-subnav" aria-label="Walkthroughs">
        <a href="/walkthroughs/one-turn/">One turn, end to end</a>
        <a href="/walkthroughs/one-tiny-tool/">One tiny tool</a>
      </div>
    </div>
    <a href="/docs/installation/">Docs</a>
    <a href="https://github.com/czyber/tinyloop">GitHub</a>
  </nav>
  <button
    class="mobile-nav-toggle"
    type="button"
    aria-label="Open navigation"
    aria-controls="mobile-nav"
    aria-expanded="false"
    data-mobile-nav-toggle
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile primary" aria-hidden="true" inert data-mobile-nav>
    <a href="/architecture/">Architecture</a>
    <a href="/principles/">Principles</a>
    <a href="/walkthroughs/">Walkthroughs</a>
    <a class="mobile-nav-child" href="/walkthroughs/one-turn/">One turn, end to end</a>
    <a class="mobile-nav-child" href="/walkthroughs/one-tiny-tool/">One tiny tool</a>
    <a href="/docs/installation/">Docs</a>
    <a href="https://github.com/czyber/tinyloop">GitHub</a>
  </nav>
</header>
