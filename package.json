{
  "name": "tinyloop-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny workspace for a minimal tool-using agent loop.",
  "scripts": {
    "start": "pnpm --filter tinyloop start",
    "demo": "pnpm --filter tinyloop start -- --demo",
    "build": "pnpm --filter tinyloop build",
    "check": "biome check . && pnpm -r typecheck",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "pack:check": "pnpm build && pnpm --filter tinyloop-agent pack --dry-run && pnpm --filter tinyloop-tui pack --dry-run && pnpm --filter tinyloop pack --dry-run"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "terminal-ui",
    "ink",
    "openai",
    "typescript"
  ],
  "author": "czyber",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czyber/tinyloop.git"
  },
  "bugs": {
    "url": "https://github.com/czyber/tinyloop/issues"
  },
  "homepage": "https://github.com/czyber/tinyloop#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1"
  }
}
