{
  "name": "tinyloop",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny workspace for a minimal tool-using agent loop.",
  "scripts": {
    "start": "pnpm --filter @tinyloop/agent start",
    "check": "biome check . && pnpm -r typecheck",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
