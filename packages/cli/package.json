{
  "name": "tinyloop",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "CLI host for tinyloop.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "tinyloop": "dist/main.js"
  },
  "license": "MIT",
  "author": "czyber",
  "keywords": [
    "agent",
    "coding-agent",
    "terminal-ui",
    "ink",
    "openai",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czyber/tinyloop.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/czyber/tinyloop/issues"
  },
  "homepage": "https://github.com/czyber/tinyloop#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prestart": "pnpm --filter tinyloop-agent build && pnpm --filter tinyloop-tui build",
    "start": "tsx src/main.tsx",
    "test": "pnpm typecheck && tsx test/auth-store.test.ts",
    "build": "pnpm --filter tinyloop-agent build && pnpm --filter tinyloop-tui build && pnpm clean && tsc",
    "typecheck": "pnpm --filter tinyloop-agent build && pnpm --filter tinyloop-tui build && tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "tinyloop-agent": "workspace:^",
    "tinyloop-tui": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
